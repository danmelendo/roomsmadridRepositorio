# ─── Supabase ───────────────────────────────────────────────────────────────
# These come from the Supabase dashboard → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # NEVER expose this in the browser

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
VITE_SUPABASE_PROJECT_ID=<project-ref>

# ─── Redsys / TPV BBVA ──────────────────────────────────────────────────────
# Set these in the Supabase Dashboard → Edge Functions → Secrets
# (NOT here — never store the real secret key in a file)
#
# REDSYS_MERCHANT_CODE      DS_MERCHANT_MERCHANTCODE  e.g. 364633586
# REDSYS_TERMINAL           DS_MERCHANT_TERMINAL      e.g. 001
# REDSYS_SECRET_KEY         Base64-encoded secret key (see note below)
# REDSYS_ENVIRONMENT        "test" | "production"
# REDSYS_MERCHANT_URL       Public URL of the redsys-notification edge function
#                           e.g. https://<project-ref>.supabase.co/functions/v1/redsys-notification
# REDSYS_URL_OK             e.g. https://reservar.roomsmadrid.es/reservar-ok
# REDSYS_URL_KO             e.g. https://reservar.roomsmadrid.es/reservar-ok
# REDSYS_BYPASS             Set to "true" to skip Redsys entirely (marks paid directly). NEVER use in production.
#
# Base64-encoding the secret key:
#   node -e "console.log(Buffer.from('YOUR_SECRET_KEY').toString('base64'))"
#
# Test environment admin portal: https://sis-t.redsys.es:25443/portalBBVA
# Test payment endpoint (used automatically when REDSYS_ENVIRONMENT=test):
#   https://sis-t.redsys.es:25443/sis/realizarPago

# ─── Email de confirmación (SMTP, en la edge function) ──────────────────────
# Configúralo como secrets en Supabase (NO aquí), Edge Functions → Secrets:
#   SMTP_HOST=mail.roomsmadrid.es
#   SMTP_PORT=465                 (465 SSL  ó  587 STARTTLS)
#   SMTP_TLS=true                 (true para 465, false para 587)
#   SMTP_USERNAME=reservas@roomsmadrid.es
#   SMTP_PASSWORD=********
#   SMTP_FROM=Rooms Madrid <reservas@roomsmadrid.es>
